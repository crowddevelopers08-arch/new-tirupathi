// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String   @id @default(cuid())
  name         String
  phone        String
  email        String?
  treatment    String?
  procedure    String?
  message      String?
  city         String?
  age          String?
  pincode      String?
  hairLossStage String?
  concerns     String?
  hairProblems String?
  consent      Boolean  @default(false)
  source       String?
  formName     String?
  status       String   @default("NEW") // NEW, CONTACTED, SCHEDULED, CONVERTED, LOST
  telecrmSynced Boolean @default(false)
  telecrmId    String?
  syncedAt     DateTime?
  error        String?
  whatsappNumber String?
  womansAgeBracket String?
  tryingDuration String?
  isWhatsapp   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("leads")
}